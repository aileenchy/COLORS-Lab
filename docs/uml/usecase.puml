@startuml
left to right direction
title Colors App - Use Case Diagram

actor User

rectangle "Colors Web Application" {
  usecase "Log In" as UC1
  usecase "Search Color" as UC2
  usecase "Add Color" as UC3
  usecase "Log Out" as UC4
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

UC2 ..> UC1 : <<include>>
UC3 ..> UC1 : <<include>>
UC4 ..> UC1 : <<include>>

@enduml
